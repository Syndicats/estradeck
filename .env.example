# Copy to ".env" (gitignored) and fill in. Loaded at server startup.

# Slides Intelligence (the inline ⌘K assistant in the Code tab) uses OpenAI directly
# for low latency. Agent mode is unaffected — it keeps using the Claude CLI.
OPENAI_API_KEY=

# Model for Slides Intelligence (optional; defaults to gpt-5.4-mini).
# SI_MODEL=gpt-5.4-mini
